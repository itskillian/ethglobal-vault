# Copy to .env and fill in. `.env` is gitignored. Foundry auto-loads it for ${VAR}
# interpolation in foundry.toml and for vm.env* in scripts.

# --- RPC endpoints (referenced by name as `--rpc-url sepolia` / `--rpc-url mainnet`) ---
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# --- Source verification ---
# Etherscan v2 multichain API key (one key verifies both Sepolia and mainnet).
ETHERSCAN_API_KEY=

# --- Optional overrides ---
# Hook owner. Leave unset to default to the deploying EOA (you must then pass --sender <addr>).
# INITIAL_OWNER=0x0000000000000000000000000000000000000000

# PoolManager override. Leave unset to use the canonical per-chain address baked into the script.
# POOL_MANAGER=0x0000000000000000000000000000000000000000

# NOTE: No PRIVATE_KEY here by design — signing uses an encrypted keystore (--account).
# See DEPLOY.md for keystore setup.
